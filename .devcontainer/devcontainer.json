{
  "name": "FacilityOS Development",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "forwardPorts": [
    3000
  ],
  "portsAttributes": {
    "3000": {
      "label": "FacilityOS",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },
  "postCreateCommand": "bash scripts/codespaces-install.sh",
  "postStartCommand": "bash scripts/codespaces-start.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}